# Hostinger Node.js Proxy Configuration
# Forwards all requests to the Node.js Express server

DirectoryIndex disabled
Options -Indexes

RewriteEngine On

# Serve real static asset files directly (CSS, JS, images, fonts)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Forward ALL other requests to the Node.js server
# Hostinger sets PORT env var; default fallback is 3000
RewriteRule ^(.*)$ http://127.0.0.1:3000/$1 [P,L]

# If ProxyPass fails, fall back to serving the SPA index.html
# This ensures navigation works even without OG injection
ErrorDocument 502 /index.html
ErrorDocument 503 /index.html

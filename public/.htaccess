# MakerLab Academy — Static SPA routing
# All routes fall back to index.html for React Router to handle

Options -Indexes
RewriteEngine On

# Serve real files/directories directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route everything else to index.html (React Router handles the URL)
RewriteRule ^ /index.html [L]

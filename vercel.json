{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "rewrites": [
        { "source": "/api/make-and-go-lead", "destination": "/api/make-and-go-lead" },
        { "source": "/admin", "destination": "/api/admin-seo" },
        { "source": "/admin/(.*)", "destination": "/api/admin-seo" },
        { "source": "/", "destination": "/api/home-seo" },
        { "source": "/(.*)", "destination": "/index.html" }
    ]
}